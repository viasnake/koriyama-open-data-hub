{
  "name": "civic-koriyama-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "docs:install": "python -m pip install -r docs/requirements.txt",
    "docs:build": "rm -rf public .tmp/sphinx-doctrees && python -m sphinx -b html -d .tmp/sphinx-doctrees -W --keep-going docs public/docs",
    "docs:prepare": "npm run docs:install && npm run docs:build",
    "deploy:production": "node scripts/deploy-production.mjs",
    "deploy:preview": "npm run docs:prepare && npx --yes wrangler versions upload",
    "check": "npm run typecheck && npm test && npm run audit:high",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit:high": "npm audit --audit-level=high",
    "rss:verify": "tsx scripts/rss/verify-feeds.ts",
    "rss:discover": "tsx scripts/rss/discover-feeds.ts",
    "rss:audit": "tsx scripts/rss/audit-feeds.ts",
    "rss:fetch": "tsx scripts/rss/fetch-entries.ts",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.3",
    "csv-parse": "^5.6.0",
    "fast-xml-parser": "^5.2.5",
    "hono": "^4.12.25",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "read-excel-file": "^9.0.10",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
